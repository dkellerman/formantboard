{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "devCommand": "vite --port $PORT",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/:path((?!api/|@vite/|@react-refresh|src/|node_modules/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
